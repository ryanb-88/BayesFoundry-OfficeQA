import math, statistics

def hp_filter(y, lamb=100):
    """HP filter. Returns (cycle, trend). lamb: 100 annual, 1600 quarterly, 14400 monthly."""
    try:
        from statsmodels.tsa.filters.hp_filter import hpfilter
        import numpy as np
        c, t = hpfilter(np.array(y, dtype=float), lamb=lamb)
        return list(c), list(t)
    except ImportError: pass
    try:
        import numpy as np
        n = len(y); y_arr = np.array(y, dtype=float); e = np.eye(n)
        D = np.zeros((n-2, n))
        for i in range(n-2): D[i,i]=1; D[i,i+1]=-2; D[i,i+2]=1
        trend = np.linalg.solve(e + lamb * D.T @ D, y_arr)
        return list(y_arr - trend), list(trend)
    except ImportError: pass
    n = len(y); y_f = [float(v) for v in y]
    d0=[0.0]*n; d1=[0.0]*n; d2=[0.0]*n
    for i in range(n):
        d0[i] = 1 + lamb*(1 if i in (0,n-1) else 5 if i in (1,n-2) else 6)
    for i in range(n-1): d1[i] = -2.0*lamb if i in (0,n-2) else -4.0*lamb
    for i in range(n-2): d2[i] = lamb
    a,b,c,e1,e2,rhs = d2[:],d1[:],d0[:],d1[:],d2[:],y_f[:]
    for i in range(n):
        if i>=1 and abs(c[i-1])>=1e-30:
            m=b[i-1]/c[i-1]; c[i]-=m*e1[i-1]
            if i<n-1 and i-1<n-2: e1[i]-=m*e2[i-1]
            rhs[i]-=m*rhs[i-1]; b[i-1]=0
        if i>=2 and abs(c[i-2])>=1e-30:
            m=a[i-2]/c[i-2]
            if i-1<n-1 and i-2<n-1: b[i-1]-=m*e1[i-2]
            if i-2<n-2: c[i]-=m*e2[i-2]
            rhs[i]-=m*rhs[i-2]; a[i-2]=0
    tau=[0.0]*n
    for i in range(n-1,-1,-1):
        val=rhs[i]
        if i<n-1: val-=e1[i]*tau[i+1]
        if i<n-2: val-=e2[i]*tau[i+2]
        tau[i]=val/c[i]
    return [y_f[i]-tau[i] for i in range(n)], tau

def ols_regression(x, y):
    n=len(x); xm=sum(x)/n; ym=sum(y)/n
    ss_xy=sum((x[i]-xm)*(y[i]-ym) for i in range(n))
    ss_xx=sum((x[i]-xm)**2 for i in range(n))
    slope=ss_xy/ss_xx; intercept=ym-slope*xm
    return slope, intercept, [slope*xi+intercept for xi in x]

def geometric_mean(values):
    return math.exp(sum(math.log(v) for v in values)/len(values))

def cagr(start_val, end_val, n_years):
    return (end_val/start_val)**(1.0/n_years) - 1

def annualized_volatility(values, periods_per_year=12, use_log_returns=False):
    if use_log_returns:
        returns=[math.log(values[i]/values[i-1]) for i in range(1,len(values))]
    else:
        returns=[values[i]-values[i-1] for i in range(1,len(values))]
    n=len(returns); mean_r=sum(returns)/n
    var=sum((r-mean_r)**2 for r in returns)/(n-1)
    return math.sqrt(var)*math.sqrt(periods_per_year)

def theil_index(values):
    """Standard Theil T index (unnormalized). Do NOT divide by ln(n)."""
    total=sum(values); n=len(values)
    shares=[v/total for v in values]
    return (1.0/n)*sum(s*math.log(n*s) for s in shares if s>0)

def pop_stdev(values):
    n=len(values); mean=sum(values)/n
    return math.sqrt(sum((v-mean)**2 for v in values)/n)

def euclidean_norm(values):
    return math.sqrt(sum(v**2 for v in values))

def coeff_of_variation_pop(values):
    n=len(values); mean=sum(values)/n
    return math.sqrt(sum((v-mean)**2 for v in values)/n)/abs(mean)

def exponential_smoothing(y, alpha):
    s=[y[0]]
    for i in range(1,len(y)): s.append(alpha*y[i]+(1-alpha)*s[-1])
    return s

def var_historical(returns, confidence=0.95):
    return sorted(returns)[int(math.floor((1-confidence)*len(returns)))]
